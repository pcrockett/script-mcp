#!/usr/bin/env -S nu --stdin

const VERSION = "0.0.1"
let TOOLS_DIR = "tools"

def main [] {
  open --raw /dev/stdin | lines | each { process-request }
  ignore
}

def process-request []: string -> nothing {
  let request = try {
    $in | from json
  } catch {
    (
      {
        error: {
          code: -32700
          message: "Parse error"
          data: "Invalid JSON received"
        }
      }
      | send-response
    )
    return
  }

  (
    {
      id: ($request | get --optional id)
      method: ($request | get --optional method)
    }
    | match ($in) {
      {id: null} => { missing-field-response id }
      {method: null} => { missing-field-response method }
      _ => { $request | process-jsonrpc-request }
    }
    | send-response ($request | get --optional id)
  )
}

def process-jsonrpc-request []: record -> record {
  let request = $in
  $request | match ($request.method) {
    "initialize" => { method_initialize }
    "tools/list" => { method_tools_list }
    "tools/call" => { method_tools_call }
    _ => {
      {
        error: {
          code: -32601
          message: "Method not found"
        }
      }
    }
  }
}

def send-response [request_id: any = null]: record -> nothing {
  let payload = $in
  (
    {
      jsonrpc: "2.0"
      id: $request_id
      ...$payload
    }
    | to json --raw
    | print
  )
}

def method_initialize []: record -> record {
  {
    result: {
      protocolVersion: "2025-11-25"
      capabilities: {
        tools: {
          listChanged: false
        }
      }
      serverInfo: {
        name: "script-mcp"
        version: $VERSION
      }
    }
  }
}

def method_tools_list []: record -> record {
  {
    result: {
      tools: (find-tools | each { $in.manifest })
    }
  }
}

def method_tools_call []: record -> record {
  let request = $in
  let name = try {
    $request.params.name
  } catch {
    return (missing-field-response "params.name")
  }
  let tool = (find-tools | where { $in.name == $name } | first)
  if ($tool | is-empty) {
    return {
      error: {
        code: -32601
        message: "Unknown tool"
        data: $"params.name = ($name)"
      }
    }
  }
  let result = (
    $request.params
    | get --optional arguments
    | default {}
    | to json --raw
    | ^$tool.path
    | complete
  )
  match ($result) {
    {exit_code: 0} => {
      {
        result: {
          content: [
            {
              type: text
              text: ($result.stdout | str trim)
            }
          ]
        }
      }
    }
    _ => { internal-error-response "Tool call failed" $"Exit code ($result.exit_code)" }
  }
}

def missing-field-response [field_name: string]: nothing -> record {
  {
    error: {
      code: -32600
      message: "Invalid request"
      data: $"Missing required field: \"($field_name)\""
    }
  }
}

def internal-error-response [message: string, data?: string]: nothing -> record {
  let error = {
    code: -32603
    message: $message
  }
  if ($data | is-empty) {
    { error: $error }
  } else {
    { error: ($error | upsert data $data) }
  }
}

def find-tools []: nothing -> list<record> {
  if not ($TOOLS_DIR | path exists) {
    return []
  }

  (
    ls $TOOLS_DIR
    | where { $in.type == "file" }
    | each {|file|
      {
        name: ($file.name | path basename)
        path: ($file.name | path expand)
      }
    }
    | each {|tool|
      let discovery = try {
        (^$tool.path discover | from json)
      } catch {
        # may optionally cause a non-fatal error response...
        # but i think outright failure is ok for now
        error make {msg: $"Discovery failed for tool \"($tool.name)\""}
      }
      let description = ($discovery | get --optional description)
      let input_schema = (
        $discovery
        | get --optional inputSchema
        | default { type: "object" }
      )
      let manifest = if ($description | is-not-empty) {
        {
          name: $tool.name
          description: $description
          inputSchema: $input_schema
        }
      } else {
        {
          name: $tool.name
          inputSchema: $input_schema
        }
      }
      $tool | upsert "manifest" $manifest
    }
  )
}
