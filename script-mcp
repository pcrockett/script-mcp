#!/usr/bin/env -S nu --stdin

const VERSION = "0.0.1"
let TOOLS_DIR = "tools"

def main [] {
  open --raw /dev/stdin | lines | each { process-request }
  ignore
}

def process-request []: string -> nothing {
  let request = try {
    $in | from json
  } catch {
    (
      {
        error: {
          code: -32700
          message: "Parse error"
          data: "Invalid JSON received"
        }
      }
      | send-response
    )
    return
  }

  (
    {
      id: ($request | get --optional id)
      method: ($request | get --optional method)
    }
    | match ($in) {
      {id: null} => { missing-field-response id }
      {method: null} => { missing-field-response method }
      _ => { $request | process-jsonrpc-request }
    }
    | send-response ($request | get --optional id)
  )
}

def process-jsonrpc-request []: record -> record {
  let request = $in
  $request | match ($request.method) {
    "initialize" => { method_initialize }
    "tools/list" => { method_tools_list }
    "tools/call" => { method_tools_call }
    _ => {
      {
        error: {
          code: -32601
          message: "Method not found"
        }
      }
    }
  }
}

def send-response [request_id: any = null]: record -> nothing {
  let payload = $in
  (
    {
      jsonrpc: "2.0"
      id: $request_id
      ...$payload
    }
    | to json --raw
    | print
  )
}

def method_initialize []: record -> record {
  {
    result: {
      protocolVersion: "2024-11-05",
      capabilities: {
        tools: {}  # yes, we provide tools
      },
      serverInfo: {
        name: "script-mcp",
        version: $VERSION
      }
    }
  }
}

def method_tools_list []: record -> record {
  {
    result: {
      tools: (find-tools | each { $in.manifest })
    }
  }
}

def method_tools_call []: record -> record {
  let request = $in
  internal-error-response "not implemented yet"
  # TODO: use code -32601 for unknown tool
}

def missing-field-response [field_name: string]: nothing -> record {
  {
    error: {
      code: -32600
      message: "Invalid request"
      data: $"Missing required field: \"($field_name)\""
    }
  }
}

def internal-error-response [message: string]: nothing -> record {
  {
    error: {
      code: -32603
      message: $message
    }
  }
}

def find-tools []: nothing -> list<record> {
  if not ($TOOLS_DIR | path exists) {
    return []
  }

  (
    ls $TOOLS_DIR
    | where { $in.type == "file" }
    | each {|file|
      {
        name: ($file.name | path basename)
        path: ($file.name | path expand)
      }
    }
    | each {|tool|
      let discovery = (^$tool.path discover | from json)
      let manifest = {
        name: $tool.name
        description: $discovery.description
        inputSchema: $discovery.inputSchema
      }
      $tool | upsert "manifest" $manifest
    }
  )
}

